<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/theme_btn_pressed" />
            <stroke android:width="1dp" android:color="@color/theme_btn_pressed" />
            <corners android:radius="5dp"/>
        </shape>
    </item>

    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/theme_btn_warning" />
            <stroke android:width="1dp" android:color="@color/theme_btn_pressed" />
            <corners android:radius="5dp"/>
        </shape>
    </item>

    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/theme_btn_disabled" />
            <stroke android:width="1dp" android:color="@color/theme_btn_border_disabled" />
            <corners android:radius="5dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/theme_btn_warning" />
            <stroke android:width="1dp" android:color="@color/theme_btn_border_warning" />
            <corners android:radius="5dp"/>
        </shape>
    </item>

</selector>
<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <padding
                    android:bottom="3dp"
                    android:left="0dp"
                    android:right="3dp"
                    android:top="0dp" />

            <gradient
                    android:startColor="#70EEEEEE"
                    android:endColor="#00FFFFFF"
                    android:angle="270" />

            <corners android:radius="2dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#ffffff"/>
            <corners android:radius="2dp" />
            <stroke
                    android:width="1dp"
                    android:color="#666" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/ui_margin_s">

        <Button
                android:id="@+id/btnSuccess"
                android:text="正常"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_s"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnDanger"
                app:layout_constraintBottom_toTopOf="@id/btnWarning"

                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_chainStyle="spread"
                app:layout_constraintVertical_weight="1"
        />

        <Button
                android:id="@+id/btnDanger"
                style="@style/AppTheme.Button.Danger"
                android:text="危險"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_s"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnSuccess"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnInfo"

                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_chainStyle="spread"
                app:layout_constraintVertical_weight="1"
        />

        <Button
                android:id="@+id/btnWarning"
                style="@style/AppTheme.Button.Warning"
                android:text="警告"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_xl"
                app:layout_constraintTop_toBottomOf="@id/btnSuccess"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnInfo"
                app:layout_constraintBottom_toTopOf="@id/btnSave"

                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"

        />

        <Button
                android:id="@+id/btnInfo"
                style="@style/AppTheme.Button.Info"
                android:text="一般"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_xl"
                app:layout_constraintTop_toBottomOf="@id/btnDanger"
                app:layout_constraintStart_toEndOf="@id/btnWarning"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnDelete"

                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"
        />

        <Button
                android:id="@+id/btnSave"
                android:text="儲存"
                android:drawableStart="@drawable/ic_save_light"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_s"
                app:layout_constraintTop_toBottomOf="@id/btnWarning"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnDelete"
                app:layout_constraintBottom_toTopOf="@id/btnCamera"

                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"
        />

        <Button
                android:id="@+id/btnDelete"
                android:text="刪除"
                style="@style/AppTheme.Button.Danger"
                android:drawableStart="@drawable/ic_trashcan_light"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ui_margin_s"
                app:layout_constraintTop_toBottomOf="@id/btnInfo"
                app:layout_constraintStart_toEndOf="@id/btnSave"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/btnTest"

                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"
        />

        <Button
                android:id="@+id/btnCamera"
                android:text="拍照"
                style="@style/AppTheme.Button.Warning"
                android:drawableStart="@drawable/ic_menu_camera"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/btnSave"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnTest"

                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"
                android:layout_marginTop="8dp"/>

        <Button
                android:id="@+id/btnTest"
                android:text="列印"
                style="@style/AppTheme.Button.Info"
                android:drawableStart="@drawable/ic_menu_print"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/btnDelete"
                app:layout_constraintStart_toEndOf="@id/btnCamera"
                app:layout_constraintEnd_toEndOf="parent"

                app:layout_constraintHorizontal_weight="1"

                app:layout_constraintVertical_weight="1"
                android:layout_marginTop="8dp"/>
        <Button
                android:text="對話視窗"
                style="@style/AppTheme.Button.Transfer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/button"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnCamera"
                app:layout_constraintEnd_toStartOf="@+id/button2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintHorizontal_chainStyle="spread"/>
        <Button
                android:text="對話視窗2"
                style="@style/AppTheme.Button.gradation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/button2"
                android:paddingStart="@dimen/ui_padding_s"
                android:paddingEnd="@dimen/ui_padding_s"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintTop_toBottomOf="@+id/btnTest"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/button"
        />


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
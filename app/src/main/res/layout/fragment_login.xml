<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:srcCompat="@mipmap/ic_launcher"
            app:layout_constraintBottom_toTopOf="@+id/textAccount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_weight="2"
            />


    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textAccount"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/ui_margin_s"
            android:layout_marginEnd="@dimen/ui_margin_s"
            android:layout_marginTop="@dimen/ui_margin_s"
            android:layout_marginBottom="@dimen/ui_margin_s"
            app:layout_constraintBottom_toTopOf="@+id/textPassword"
            app:layout_constraintTop_toBottomOf="@+id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_weight="1"
            app:counterEnabled="true"
            app:counterMaxLength="5">

        <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="帳號"
                android:id="@+id/editAccount"
                android:singleLine="true"
                android:textSize="@dimen/text_size_xl"
                android:nextFocusDown="@id/textPassword"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/textPassword"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/ui_margin_s"
            android:layout_marginEnd="@dimen/ui_margin_s"
            android:layout_marginTop="@dimen/ui_margin_s"
            android:layout_marginBottom="@dimen/ui_margin_s"
            app:layout_constraintBottom_toTopOf="@id/btnLogin"
            app:layout_constraintTop_toBottomOf="@id/textAccount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_weight="1">

        <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="密碼"
                android:id="@+id/editPassword"
                android:singleLine="true"
                android:textSize="@dimen/text_size_xl"
                android:nextFocusDown="@id/btnLogin"
                android:inputType="textPassword"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
            android:text="登入"
            android:id="@+id/btnLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/ui_margin_s"
            android:layout_marginEnd="@dimen/ui_margin_s"
            android:layout_marginTop="@dimen/ui_margin_s"
            android:layout_marginBottom="@dimen/ui_margin_s"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintVertical_weight="2"
            app:layout_constraintHorizontal_bias="1"
    />


</androidx.constraintlayout.widget.ConstraintLayout>
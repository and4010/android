<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                                   xmlns:tools="http://schemas.android.com/tools"
                                                   android:layout_width="match_parent"
                                                   android:layout_height="match_parent">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                  android:orientation="vertical"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_margin="@dimen/ui_margin_m"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent">
        <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="center"
                android:background="@color/them_btn_background"
                android:src="@drawable/ic_search"/>
        <EditText
                android:id="@+id/username"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/ui_margin_xxl"
                android:layout_marginLeft="@dimen/ui_margin_s"
                android:layout_marginRight="@dimen/ui_margin_s"
                android:layout_marginBottom="@dimen/ui_margin_s"
                android:hint="username"
                android:singleLine="true"/>
        <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/ui_margin_s"
                android:layout_marginLeft="@dimen/ui_margin_s"
                android:layout_marginRight="@dimen/ui_margin_s"
                android:layout_marginBottom="@dimen/ui_margin_xxl"
                android:fontFamily="sans-serif"
                android:hint="password"
                android:singleLine="true"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="@dimen/ui_padding_xs"
        android:paddingRight="@dimen/ui_padding_xs"
        android:paddingTop="@dimen/ui_padding_s"
        android:paddingBottom="@dimen/ui_padding_s"
        android:layout_margin="@dimen/ui_margin_xs">

    <TextView
            android:id="@+id/txtKey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/ui_margin_xs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/edtValue"
            app:layout_constraintBottom_toBottomOf="parent"
            android:gravity="center_vertical"
            android:textAlignment="center"
            android:textColor="@color/colorAccent"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="3"
    />

    <EditText
            android:id="@+id/edtValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/ui_margin_xl"
            android:layout_marginEnd="@dimen/ui_margin_l"
            android:background="@null"
            app:layout_constraintStart_toEndOf="@id/txtKey"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/linearLayoutButton"
            app:layout_constraintBottom_toBottomOf="parent"
            android:textAlignment="textStart"
            app:layout_constraintHorizontal_weight="8"
    />
    <LinearLayout
        android:id="@+id/linearLayoutButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/edtValue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center"
        >
        <ImageView
                android:id="@+id/btnAction"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:src="@drawable/ic_delete"
            android:layout_weight="1"
            android:scaleType="center"
        />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
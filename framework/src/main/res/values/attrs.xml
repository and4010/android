<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="StandardEditText">
        <attr name="android:text" />
        <attr name="android:hint"  />
        <attr name="android:title"  />
        <attr name="android:inputType" />
        <attr name="android:textSize" />
        <attr name="android:maxLength" />
        <attr name="android:icon" />
        <attr name="android:selectAllOnFocus" />
        <attr name="pattern" format="enum" >
            <enum name="standard" value="0" />
            <enum name="button_less" value="1" />
            <enum name="title_less" value="2" />
            <enum name="text_only" value="3" />
        </attr>
    </declare-styleable>

    <declare-styleable name="StandardTextView">
        <attr name="android:text" />
        <attr name="android:title"  />
        <attr name="android:textSize" />
        <attr name="android:icon" />
    </declare-styleable>
</resources>
